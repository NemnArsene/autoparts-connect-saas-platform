# AutoParts Connect — Environment Variables
# Copy to .env.local and fill in values

# API
MONGODB_URI=mongodb://localhost:27017/autoparts-connect
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PORT=3001

# Mobile (Expo EAS)
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# Push Notifications (Firebase)
FCM_SERVER_KEY=
