{
  "name": "@autoparts/hooks",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@autoparts/models": "workspace:*",
    "@autoparts/shared": "workspace:*",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  }
}
