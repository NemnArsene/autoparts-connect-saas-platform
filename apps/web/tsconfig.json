{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@autoparts/models": ["../../packages/models/src/index.ts"],
      "@autoparts/shared": ["../../packages/shared/src/index.ts"],
      "@autoparts/validators": ["../../packages/validators/src/index.ts"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"]
}
