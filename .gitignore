# =============================================================================
# AutoParts Connect — .gitignore
# Turborepo Monorepo (Expo/RN + React/Vite + NestJS)
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build outputs & compiled files
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/

# Expo / React Native compiled output
android/
ios/
.expo/
.expo-shared/
expo-env.d.ts

# NestJS compiled output
apps/api/dist/

# Turborepo cache
.turbo/

# TypeScript compiled output
*.js.map
*.d.ts
# (do not ignore .d.ts inside packages/*/src if generated by build, uncomment below if needed)
# !packages/*/src/**/*.d.ts

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
# Keep .env.example committed as a template
!.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.tsbuildinfo
.cache/
.parcel-cache/

# Lock files (keep pnpm-lock.yaml, ignore others to avoid conflicts)
package-lock.json
yarn.lock
nul
